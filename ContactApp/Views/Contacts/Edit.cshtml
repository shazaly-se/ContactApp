@model ContactApp.Models.Contact

<h2>Edit Contact</h2>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="All" class="text-danger"></div>

    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ProfileImage" />
    <div class="form-group">
        <label asp-for="FirstName"></label>
        <input asp-for="FirstName" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="LastName"></label>
        <input asp-for="LastName" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Phone"></label>
        <input asp-for="Phone" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
    </div>
    <br>
    @if (!string.IsNullOrEmpty(Model.ProfileImage))
    {
        <img src="https://contactproject.blob.core.windows.net/contactimages/@Model.ProfileImage" width="100" class="mb-2" />
    }
    <div class="form-group">
        <label asp-for="ProfileImage">Change Profile Image</label>
        <input asp-for="ProfileImage" class="form-control" type="file"  />
    </div>
    <br />

    <button type="submit" class="btn btn-primary">Update</button>

</form>